<div class="books-section" style="background-color: #f8f0ff; padding: 3rem 0; border-radius: 15px;">
  <div class="container">
    <h1 class="text-center mb-4"><i class="fas fa-book-open book-icon"></i> My Favorite Books</h1>
    
    <div class="row row-cols-1 row-cols-md-2 g-4">
      <!-- Little Women -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'littlewomen.jpg', class: 'img-fluid rounded-start book-cover', alt: 'Little Women cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "Little Women", "https://www.goodreads.com/book/show/1934.Little_Women", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">Louisa May Alcott | Classic</small></p>
                <p class="card-text">The story of the four March sisters and their journey from childhood to womanhood.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/1934.Little_Women", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Life in Letters -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'lifeinletters.jpg', class: 'img-fluid rounded-start book-cover', alt: 'Life in Letters cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "Life in Letters", "https://www.goodreads.com/book/show/157991.Life_in_Letters", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">F. Scott Fitzgerald | Biography</small></p>
                <p class="card-text">A collection of Fitzgeralds personal letters that reveal his inner life.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/157991.Life_in_Letters", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- And Then There Were None -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'andthentherewasnone.jpg', class: 'img-fluid rounded-start book-cover', alt: 'And Then There Were None cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "And Then There Were None", "https://www.goodreads.com/book/show/16299.And_Then_There_Were_None", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">Agatha Christie | Mystery</small></p>
                <p class="card-text">Ten strangers are invited to an island, only to be killed one by one.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/16299.And_Then_There_Were_None", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Crime and Punishment -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'crimeandpunishment.jpg', class: 'img-fluid rounded-start book-cover', alt: 'Crime and Punishment cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "Crime and Punishment", "https://www.goodreads.com/book/show/7144.Crime_and_Punishment", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">Fyodor Dostoevsky | Psychological Fiction</small></p>
                <p class="card-text">A former students mental anguish after he murders an unscrupulous pawnbroker.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/7144.Crime_and_Punishment", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Alias Grace -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'aliasgrace.jpg', class: 'img-fluid rounded-start book-cover', alt: 'Alias Grace cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "Alias Grace", "https://www.goodreads.com/book/show/34497.Alias_Grace", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">Margaret Atwood | Historical Fiction</small></p>
                <p class="card-text">Based on the true story of Grace Marks, a housemaid convicted of murder in 1843 Canada.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/34497.Alias_Grace", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Anna Karenina -->
      <div class="col">
        <div class="card h-100 book-card">
          <div class="row g-0">
            <div class="col-md-4">
              <%= image_tag 'annakarenina.jpg', class: 'img-fluid rounded-start book-cover', alt: 'Anna Karenina cover' %>
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to "Anna Karenina", "https://www.goodreads.com/book/show/15823480-anna-karenina", target: "_blank", class: "book-link" %>
                </h5>
                <p class="card-text"><small class="text-muted">Leo Tolstoy | Classic Literature</small></p>
                <p class="card-text">The tragic story of a married aristocrats affair with the affluent Count Vronsky.</p>
                <%= link_to "View on Goodreads", "https://www.goodreads.com/book/show/15823480-anna-karenina", target: "_blank", class: "btn btn-goodreads" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-4">
      <%= link_to "Back to Home", root_path, class: "btn btn-purple" %>
    </div>
  </div>
</div>